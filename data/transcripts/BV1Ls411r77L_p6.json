      "start": 232.12,
      "end": 232.64,
      "text": "我跟你说"
    },
    {
      "start": 232.64,
      "end": 233.32,
      "text": "人真意味著"
    },
    {
      "start": 233.32,
      "end": 234.72,
      "text": "最重要的特点是什么"
    },
    {
      "start": 234.72,
      "end": 235.88,
      "text": "你要有自己之名"
    },
    {
      "start": 235.88,
      "end": 236.68,
      "text": "能明白吧"
    },
    {
      "start": 236.68,
      "end": 237.16,
      "text": "但同学"
    },
    {
      "start": 237.16,
      "end": 238.2,
      "text": "你要有会发现"
    },
    {
      "start": 238.2,
      "end": 239.4,
      "text": "那些人不喜欢你的"
    },
    {
      "start": 239.4,
      "end": 240.12,
      "text": "你有标为他们"
    },
    {
      "start": 240.12,
      "end": 240.92,
      "text": "突不改变吗"
    },
    {
      "start": 240.92,
      "end": 242.2,
      "text": "没有标对不对"
    },
    {
      "start": 242.2,
      "end": 242.64,
      "text": "你比如说"
    },
    {
      "start": 242.64,
      "end": 243.36,
      "text": "那我来举例子"
    },
    {
      "start": 243.36,
      "end": 243.84,
      "text": "每年"
    },
    {
      "start": 243.84,
      "end": 244.44,
      "text": "每年就是"
    },
    {
      "start": 244.44,
      "end": 245.8,
      "text": "有那100%的人"
    },
    {
      "start": 245.8,
      "end": 246.48,
      "text": "不喜欢我"
    },
    {
      "start": 246.48,
      "end": 247.52,
      "text": "我没有标为他们"
    },
    {
      "start": 247.52,
      "end": 247.92,
      "text": "突不改变"
    },
    {
      "start": 247.92,
      "end": 248.44,
      "text": "对不对"
    },
    {
      "start": 248.44,
      "end": 249.12,
      "text": "我就是我"
    },
    {
      "start": 249.12,
      "end": 249.84,
      "text": "我怎么就在这儿"
    },
    {
      "start": 249.84,
      "end": 250.2,
      "text": "掩火"
    },
    {
      "start": 250.2,
      "end": 250.68,
      "text": "把你保"
    },
    {
      "start": 251.48,
      "end": 252.04,
      "text": "你也不能"
    },
    {
      "start": 252.04,
      "end": 252.64,
      "text": "打我打气嘛"
    },
    {
      "start": 252.64,
      "end": 253.08,
      "text": "对吧"
    },
    {
      "start": 253.08,
      "end": 253.56,
      "text": "所以同学"
    },
    {
      "start": 253.56,
      "end": 253.92,
      "text": "你要知道"
    },
    {
      "start": 253.92,
      "end": 254.84,
      "text": "不管在学校里面"
    },
    {
      "start": 254.84,
      "end": 255.88,
      "text": "还是在记录社会"
    },
    {
      "start": 255.88,
      "end": 256.8,
      "text": "你们都要怎么样"
    },
    {
      "start": 256.8,
      "end": 257.92,
      "text": "又用于做自己"
    },
    {
      "start": 257.92,
      "end": 258.6,
      "text": "能明白的"
    },
    {
      "start": 258.6,
      "end": 259.28,
      "text": "你要记住"
    },
    {
      "start": 259.28,
      "end": 260.56,
      "text": "同学能够百分之七八十"
    },
    {
      "start": 260.56,
      "end": 261.24,
      "text": "的人喜欢你"
    },
    {
      "start": 261.24,
      "end": 261.68,
      "text": "你做的"
    },
    {
      "start": 261.68,
      "end": 263.4,
      "text": "就已经很到位了"
    },
    {
      "start": 263.4,
      "end": 264.2,
      "text": "把你所不可能"
    },
    {
      "start": 264.2,
      "end": 265.08,
      "text": "做的人都喜欢你的"
    },
    {
      "start": 265.08,
      "end": 265.68,
      "text": "知道吧"
    },
    {
      "start": 265.68,
      "end": 266.32,
      "text": "如果说你对人"
    },
    {
      "start": 266.32,
      "end": 267.4,
      "text": "这种标篮的精采的话"
    },
    {
      "start": 267.4,
      "end": 267.64,
      "text": "你看"
    },
    {
      "start": 267.64,
      "end": 268.92,
      "text": "今天咱们需要给大家"
    },
    {
      "start": 268.92,
      "end": 269.8,
      "text": "提供的这样一个机会"
    },
    {
      "start": 269.8,
      "end": 270.32,
      "text": "对不对"
    },
    {
      "start": 270.32,
      "end": 270.8,
      "text": "咱们学院"
    },
    {
      "start": 270.8,
      "end": 271.52,
      "text": "你看来了这么多人"
    },
    {
      "start": 271.52,
      "end": 272.0,
      "text": "对不对"
    },
    {
      "start": 272.0,
      "end": 272.68,
      "text": "等会儿教我们客业"
    },
    {
      "start": 272.68,
      "end": 273.2,
      "text": "和同学"
    },
    {
      "start": 273.2,
      "end": 273.64,
      "text": "你先别走"
    },
    {
      "start": 273.64,
      "end": 273.92,
      "text": "你要想"
    },
    {
      "start": 273.92,
      "end": 274.32,
      "text": "观众就这么"
    },
    {
      "start": 274.32,
      "end": 274.68,
      "text": "精采的话"
    },
    {
      "start": 274.68,
      "end": 275.28,
      "text": "你都知道"
    },
    {
      "start": 275.28,
      "end": 275.52,
      "text": "知道吧"
    },
    {
      "start": 275.52,
      "end": 275.96,
      "text": "我下去"
    },
    {
      "start": 275.96,
      "end": 276.44,
      "text": "你上来"
    },
    {
      "start": 276.44,
      "end": 276.96,
      "text": "我把这个话"
    },
    {
      "start": 276.96,
      "end": 277.32,
      "text": "统给你"
    },
    {
      "start": 277.32,
      "end": 277.76,
      "text": "知道吧"
    },
    {
      "start": 277.76,
      "end": 278.56,
      "text": "你当得这么多人"
    },
    {
      "start": 278.56,
      "end": 279.04,
      "text": "让你的待遭"
    },
    {
      "start": 279.04,
      "end": 279.84,
      "text": "就这样也一话"
    },
    {
      "start": 279.84,
      "end": 280.48,
      "text": "大家好"
    },
    {
      "start": 280.48,
      "end": 281.0,
      "text": "我聊天"
    },
    {
      "start": 281.0,
      "end": 281.28,
      "text": "是不大学"
    },
    {
      "start": 281.28,
      "end": 281.84,
      "text": "物理学院的"
    },
    {
      "start": 281.84,
      "end": 282.4,
      "text": "我叫上下下"
    },
    {
      "start": 282.4,
      "end": 283.2,
      "text": "我标篮"
    },
    {
      "start": 283.2,
      "end": 283.68,
      "text": "你不我"
    },
    {
      "start": 283.68,
      "end": 284.6,
      "text": "你知道吧"
    },
    {
      "start": 284.6,
      "end": 285.0,
      "text": "对"
    },
    {
      "start": 285.0,
      "end": 285.84,
      "text": "你不说的"
    },
    {
      "start": 285.84,
      "end": 286.48,
      "text": "你的机械"
    },
    {
      "start": 286.48,
      "end": 287.24,
      "text": "跟别人看到"
    },
    {
      "start": 287.24,
      "end": 288.44,
      "text": "对不对"
    },
    {
      "start": 288.44,
      "end": 289.24,
      "text": "口才边的"
    },
    {
      "start": 289.24,
      "end": 289.6,
      "text": "怎么好"
    },
    {
      "start": 289.6,
      "end": 290.0,
      "text": "咱们边的"
    },
    {
      "start": 290.0,
      "end": 291.2,
      "text": "讨一些这个学会来了"
    },
    {
      "start": 291.2,
      "end": 291.68,
      "text": "第一度开始"
    },
    {
      "start": 291.68,
      "end": 292.2,
      "text": "我们第二度"
    },
    {
      "start": 292.2,
      "end": 292.44,
      "text": "不要脸"
    },
    {
      "start": 292.44,
      "end": 293.0,
      "text": "知道吧"
    },
    {
      "start": 293.0,
      "end": 294.4,
      "text": "林伯所所张学峰老师"
    },
    {
      "start": 294.4,
      "end": 295.68,
      "text": "观看更多型的容"
    },
    {
      "start": 295.68,
      "end": 296.08,
      "text": "我在这"
    }
  ],
